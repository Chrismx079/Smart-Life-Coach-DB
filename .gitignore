# --- SEGURIDAD Y CONFIGURACIÓN ---
# Nunca subir las llaves secretas o configuración local
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- DEPENDENCIAS ---
# Carpeta de librerías (se regenera con npm install)
node_modules/
jspm_packages/
.pnpm-store/

# --- SUPABASE ---
# Ignorar datos temporales y archivos de estado local
supabase/.temp/
supabase/storage/
.supabase/

# --- SISTEMA OPERATIVO ---
# Archivos basura generados por Windows y macOS
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# --- LOGS Y DEPURACIÓN ---
# Archivos de error y registros de ejecución
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# --- CONFIGURACIÓN DE EDITORES ---
# Ajustes personales de VS Code u otros editores
.vscode/
.idea/
*.swo
.ntvs
*.njsproj
